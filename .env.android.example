# Android build-time environment variables
# Copy values into `.env.android` or CI before running mobile:build.

# Required — same as web (`import.meta.env.VITE_API_URL` only).
VITE_API_URL=https://api.net360preparation.com

# Required in Android builds so stripped media resolves from CDN/S3.
VITE_S3_BASE_URL=https://net360-media.s3.ap-south-1.amazonaws.com

# Required for Firebase auth flows inside APK/WebView.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Optional push notification feature flag.
VITE_ENABLE_PUSH_NOTIFICATIONS=false
