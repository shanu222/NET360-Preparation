# Android build-time environment variables
# Copy values into .env.production (or CI build environment) before running mobile:build.

# Required for real backend sync in native builds.
VITE_API_BASE_URL=https://your-api-domain.com

# Optional override used only on native runtime.
# If omitted, VITE_API_BASE_URL is used.
VITE_MOBILE_API_BASE_URL=https://your-api-domain.com

# Keep false during local/mobile QA if you want offline fallback behavior.
VITE_FORCE_LOCAL_API=false

# Set true for production releases to enforce live backend only.
VITE_DISABLE_LOCAL_API_FALLBACK=true

# Optional push notification feature flag.
VITE_ENABLE_PUSH_NOTIFICATIONS=false
