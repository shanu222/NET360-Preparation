# Backend
MONGODB_URI=
API_PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=https://net360-admin-production.up.railway.app,https://net360-preparation-production.up.railway.app,http://localhost:5173
MAX_JSON_BODY_MB=10
REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=50
ADMIN_EMAILS=admin@example.com

# Auth hardening (production defaults are secure: cookies only, no JWT in JSON, no ?token= on API)
# Set ISSUE_AUTH_BODY_TOKENS=true only for native clients that cannot use httpOnly cookies.
ISSUE_AUTH_BODY_TOKENS=
# Allow access token in query string (e.g. legacy SSE). Prefer false in production.
ALLOW_QUERY_TOKEN_AUTH=
# Set true in production when the site is served only over HTTPS (recommended).
AUTH_COOKIE_SECURE=

# Password recovery providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# Frontend (Vite)
# Preferred backend URL key for frontend apps.
VITE_API_URL=http://localhost:4000
# Backward-compatible alias.
VITE_API_BASE_URL=http://localhost:4000
# Legacy CRA-compatible alias (optional).
REACT_APP_API_URL=
VITE_MOBILE_API_BASE_URL=
VITE_DEV_API_ORIGIN=http://localhost:4000
VITE_FORCE_LOCAL_API=false
VITE_DISABLE_LOCAL_API_FALLBACK=false
# Student app: set true for Capacitor / WebViews that must store JWTs in localStorage (default: false in production builds).
VITE_STORE_AUTH_TOKENS=
