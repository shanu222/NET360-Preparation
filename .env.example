# Backend
MONGODB_URI=
API_PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:5173
MAX_JSON_BODY_MB=10
REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=50
ADMIN_EMAILS=admin@example.com

# Password recovery providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:4000
VITE_MOBILE_API_BASE_URL=
VITE_DEV_API_ORIGIN=http://localhost:4000
VITE_FORCE_LOCAL_API=false
VITE_DISABLE_LOCAL_API_FALLBACK=false
