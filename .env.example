# Optional: set DEBUG_AUTH=true to log non-sensitive login diagnostics (avoid in public production).
# Optional: ALLOW_OPEN_REGISTER=true enables POST /api/auth/register-fallback (emergency use only).
DEBUG_AUTH=
ALLOW_OPEN_REGISTER=

API_PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Include every browser origin that calls this API (comma-separated, no trailing slashes).
# Defaults in code include Vercel + local dev; set this to add more (e.g. a custom domain).
CORS_ALLOWED_ORIGINS=https://net-360-preparation.vercel.app,http://localhost:3000,http://localhost:5173
# Add custom domains (e.g. https://net360preparation.com) here, comma-separated, no trailing slashes.
CORS_EXTRA_ORIGINS=
# true = allow any *.vercel.app preview origin (credentialed).
CORS_ALLOW_VERCEL=false
MAX_JSON_BODY_MB=10
REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=50
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=
ALLOW_WEAK_JWT_BOOTSTRAP=

# AES-256-GCM key for optional encrypted copy of security answer (admin plaintext view only; bcrypt remains canonical).
# Generate: openssl rand -base64 32   (must decode to 32 bytes) or 64 hex chars.
SECURITY_ANSWER_ENCRYPTION_KEY=

# Auth hardening (production defaults are secure: cookies only, no JWT in JSON, no ?token= on API)
# Set ISSUE_AUTH_BODY_TOKENS=true only for native clients that cannot use httpOnly cookies.
ISSUE_AUTH_BODY_TOKENS=
# Allow access token in query string (e.g. legacy SSE). Prefer false in production.
ALLOW_QUERY_TOKEN_AUTH=
# HttpOnly auth cookies: secure=true and SameSite=None when NODE_ENV=production (HTTPS API required for browsers).
# Development uses secure=false and SameSite=lax.

# Password recovery providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# Frontend (Vite). All API calls use import.meta.env.VITE_API_URL only (no local/offline fallback).
# Local dev: create `.env` or `.env.development` with e.g. VITE_API_URL=http://localhost:5000
# Production / CI: committed `.env.production` sets https://api.net360preparation.com
VITE_API_URL=http://localhost:5000
# Student app: set true for Capacitor / WebViews that must store JWTs in localStorage (default: false in production builds).
VITE_STORE_AUTH_TOKENS=

# AWS S3 uploads (admin POST /api/upload). Uses AWS SDK default credential chain if keys omitted (e.g. IAM role).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Legacy aliases also supported: AWS_ACCESS_KEY, AWS_SECRET_KEY
AWS_BUCKET_NAME=
# Optional: CloudFront or custom CDN base (no trailing slash). If unset, URLs use virtual-hosted S3 style.
AWS_PUBLIC_BASE_URL=
# public-read | none — use none if bucket uses BucketOwnerEnforced / ACLs disabled.
S3_OBJECT_ACL=public-read
