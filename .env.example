# Optional: set DEBUG_AUTH=true to log non-sensitive login diagnostics (avoid in public production).
# Optional: ALLOW_OPEN_REGISTER=true enables POST /api/auth/register-fallback (emergency use only).
DEBUG_AUTH=
ALLOW_OPEN_REGISTER=

API_PORT=5000
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# CORS: server always allows apex + www production origins; merge extras here (comma-separated, no trailing slashes).
# Example: Vercel preview — https://net-360-preparation.vercel.app
CORS_ALLOWED_ORIGINS=https://net-360-preparation.vercel.app
# Do NOT set a single-origin env that overrides www vs apex (removed legacy CORS_ORIGIN).
# true = allow any *.vercel.app preview origin (credentialed).
CORS_ALLOW_VERCEL=false
MAX_JSON_BODY_MB=10
REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=50
# Admin role is stored on the user document in MongoDB only (no env-based admin list).
ALLOW_WEAK_JWT_BOOTSTRAP=

# AES-256-GCM key for optional encrypted copy of security answer (admin plaintext view only; bcrypt remains canonical).
# Generate: openssl rand -base64 32   (must decode to 32 bytes) or 64 hex chars.
SECURITY_ANSWER_ENCRYPTION_KEY=

# Auth hardening (production defaults are secure: cookies only, no JWT in JSON, no ?token= on API)
# Set ISSUE_AUTH_BODY_TOKENS=true only for native clients that cannot use httpOnly cookies.
ISSUE_AUTH_BODY_TOKENS=
# Allow access token in query string (e.g. legacy SSE). Prefer false in production.
ALLOW_QUERY_TOKEN_AUTH=
# HttpOnly auth cookies: secure=true and SameSite=None when NODE_ENV=production (HTTPS API required for browsers).
# Development uses secure=false and SameSite=lax.

# Password recovery providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# Frontend (Vite). All API calls use import.meta.env.VITE_API_URL only (no local/offline fallback).
# Local dev: create `.env` or `.env.development` with e.g. VITE_API_URL=http://localhost:5000
# Production: committed `.env.production` sets https://api.net360preparation.com (override on Vercel if needed).
VITE_API_URL=http://localhost:5000
# Student app: set true for Capacitor / WebViews that must store JWTs in localStorage (default: false in production builds).
VITE_STORE_AUTH_TOKENS=

# AWS S3 uploads (admin POST /api/upload). Streams via multer-s3. Uses AWS SDK default credential chain if keys omitted (e.g. IAM role).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Legacy aliases also supported: AWS_ACCESS_KEY, AWS_SECRET_KEY
AWS_BUCKET_NAME=
# Canonical public origin for uploaded objects (no trailing slash). Preferred over AWS_PUBLIC_BASE_URL for new deployments.
# Example: https://net360-media.s3.ap-south-1.amazonaws.com
S3_BASE_URL=
# Optional: CloudFront or legacy alias — used when S3_BASE_URL is unset (upload URL + media-config fallback).
AWS_PUBLIC_BASE_URL=
# public-read | none — use none if bucket uses BucketOwnerEnforced / ACLs disabled.
S3_OBJECT_ACL=public-read

# Public static assets (S3/CloudFront). Used by GET /api/public/media-config and PDF reports (PUBLIC_BRAND_LOGO_URL).
# Defaults to S3_BASE_URL when set; otherwise PUBLIC_MEDIA_BASE_URL / AWS_PUBLIC_BASE_URL / production bucket host in code.
PUBLIC_MEDIA_BASE_URL=
PUBLIC_BRAND_LOGO_URL=
PUBLIC_USER_GUIDE_VIDEO_URL=
PUBLIC_LOGIN_BANNER_URL=
PUBLIC_APP_PROMO_IMAGE_URL=
PUBLIC_FAVICON_URL=

# Frontend (Vite). Prefer VITE_S3_BASE_URL (same host as S3_BASE_URL / uploads).
# Example: https://net360-media.s3.ap-south-1.amazonaws.com
VITE_S3_BASE_URL=
# Legacy alias — still supported if VITE_S3_BASE_URL is unset.
# Example: https://net360-media.s3.ap-south-1.amazonaws.com/static
VITE_PUBLIC_MEDIA_BASE_URL=
VITE_BRAND_LOGO_URL=
VITE_USER_GUIDE_VIDEO_URL=
VITE_LOGIN_BANNER_URL=
VITE_APP_PROMO_IMAGE_URL=
