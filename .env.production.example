# Production frontend (Vite). Vercel: set VITE_API_URL to the public API:
#   https://api.net360preparation.com
# Copy to .env.production:   cp .env.production.example .env.production
# (.env.production is gitignored.)

VITE_API_URL=https://api.net360preparation.com
VITE_API_BASE_URL=https://api.net360preparation.com
VITE_DEV_API_ORIGIN=http://localhost:5000
# Vercel: add the app URL to server CORS (defaults include https://net-360-preparation.vercel.app; use CORS_ALLOWED_ORIGINS for more).
VITE_DISABLE_LOCAL_API_FALLBACK=true
