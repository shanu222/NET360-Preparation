# Production frontend (Vite).
# This repo commits `.env.production` with the API URL for reproducible builds.
# Override in CI/host env if needed.

VITE_API_URL=https://api.net360preparation.com
VITE_S3_BASE_URL=https://net360-media.s3.ap-south-1.amazonaws.com

# Firebase client (public). Prefer the Web app ID from the Firebase console for browser builds; Android builds can infer from google-services.json via `npm run mobile:build`.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
