<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">
            api.net360preparation.com
        </domain>

        <domain includeSubdomains="true">
            net360-media.s3.ap-south-1.amazonaws.com
        </domain>

        <domain includeSubdomains="true">
            net360preparation.com
        </domain>

        <domain includeSubdomains="true">www.net360preparation.com</domain>

        <!-- Firebase / Google Identity (HTTPS; listed for explicit coverage in WebView builds) -->
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">gstatic.com</domain>
        <domain includeSubdomains="true">google.com</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">firebase.googleapis.com</domain>
    </domain-config>

</network-security-config>