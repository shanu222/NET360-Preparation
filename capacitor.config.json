{
  "appId": "com.net360.preparation",
  "appName": "NET360 Preparation",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "localhost",
      "127.0.0.1",
      "accounts.google.com",
      "oauth2.googleapis.com",
      "www.googleapis.com",
      "apis.google.com",
      "play.google.com",
      "google.com",
      "*.google.com",
      "*.googleapis.com",
      "*.gstatic.com",
      "*.googleusercontent.com",
      "*.firebaseapp.com",
      "*.web.app"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 900,
      "launchAutoHide": true,
      "showSpinner": false,
      "backgroundColor": "#eef0ff"
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "DARK",
      "backgroundColor": "#eef0ff"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "SocialLogin": {
      "providers": {
        "google": true,
        "facebook": false,
        "apple": false,
        "twitter": false
      }
    }
  }
}
